<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sukup Land — Private Land Holdings</title>
  <meta name="description" content="Affordable vacant lots for sale. Cash deals and owner financing available. Sukup Capital Partners, LLC." />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>💲</text></svg>" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Cormorant+Garamond:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.9/babel.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { margin: 0; background: #0d0c08; }
    ::selection { background: rgba(201,162,39,0.3); color: #e8e4d9; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    input[type="range"] { accent-color: #c9a227; }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(201,162,39,0.2); border-radius: 3px; }
  </style>
</head>
<body>
  <div id="root"></div>
  <script type="text/babel">
    const { useState, useEffect, useCallback, useRef } = React;

    const EMPTY_LISTING = {
      address: "", city: "", county: "", state: "",
      acreage: "", parcelId: "", purchasePrice: "", askingPrice: "",
      status: "available", description: "", features: [],
      dateAcquired: new Date().toISOString().slice(0, 10),
      sellerFinance: false, sfDown: "", sfMonthly: "", sfTermMonths: "24",
    };

    const FEATURE_OPTIONS = [
      "Road Access", "Electric Nearby", "Water Available", "Sewer/Septic Ready",
      "Level Lot", "Corner Lot", "No HOA", "Fenced",
      "City Limits", "Owner Financing", "Mobile Home OK", "RV Friendly",
    ];

    const STATUS_MAP = {
      available: { label: "Available", color: "#c9a227", bg: "rgba(201,162,39,0.1)", border: "rgba(201,162,39,0.25)" },
      pending: { label: "Under Contract", color: "#e8c84a", bg: "rgba(232,200,74,0.08)", border: "rgba(232,200,74,0.2)" },
      sold: { label: "Sold", color: "#6b7280", bg: "rgba(107,114,128,0.1)", border: "rgba(107,114,128,0.2)" },
      holding: { label: "Holding", color: "#8b7355", bg: "rgba(139,115,85,0.1)", border: "rgba(139,115,85,0.2)" },
    };

    const STORAGE_KEY = "sukup-listings-data";
    const ADMIN_KEY = "sukup-admin-auth";
    const LEDGER_KEY = "sukup-ledger-data";
    const ANALYZER_KEY = "sukup-analyzer-data";

    function fmt(n) { return Number(n).toLocaleString("en-US", { maximumFractionDigits: 0 }); }
    function fmt2(n) { return Number(n).toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }

    function loadData() {
      try { const raw = localStorage.getItem(STORAGE_KEY); if (raw) return JSON.parse(raw); } catch {}
      return { listings: [], nextId: 1 };
    }
    function saveData(data) {
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); } catch {}
    }

    function GoldDivider({ style }) {
      return (
        <div style={{
          height: 1,
          background: "linear-gradient(90deg, transparent 0%, rgba(201,162,39,0.4) 20%, rgba(201,162,39,0.6) 50%, rgba(201,162,39,0.4) 80%, transparent 100%)",
          ...style,
        }} />
      );
    }

    /* ═══ LISTING CARD ═══ */

    function ListingCard({ listing, onEdit, isPublic }) {
      const st = STATUS_MAP[listing.status] || STATUS_MAP.available;
      const profit = listing.askingPrice && listing.purchasePrice
        ? Number(listing.askingPrice) - Number(listing.purchasePrice) : null;
      const [hover, setHover] = useState(false);

      return (
        <div
          style={{
            background: "var(--card)", borderRadius: 2, border: "1px solid var(--border)",
            overflow: "hidden", cursor: isPublic ? "default" : "pointer", position: "relative",
            transition: "all 0.35s cubic-bezier(.25,.1,.25,1)",
            transform: hover ? "translateY(-3px)" : "none",
            boxShadow: hover ? "0 16px 48px rgba(0,0,0,0.4), 0 0 0 1px rgba(201,162,39,0.15)" : "0 2px 8px rgba(0,0,0,0.2)",
          }}
          onClick={function() { if (!isPublic && onEdit) onEdit(listing); }}
          onMouseEnter={function() { setHover(true); }}
          onMouseLeave={function() { setHover(false); }}
        >
          <div style={{ height: 3, background: "linear-gradient(90deg, transparent, var(--gold), var(--gold-light), var(--gold), transparent)" }} />
          <div style={{
            height: 160, position: "relative", overflow: "hidden",
            background: "linear-gradient(160deg, #0d0c08 0%, #1a1710 40%, #0d0c08 100%)",
          }}>
            <svg style={{ position: "absolute", inset: 0, width: "100%", height: "100%", opacity: 0.04 }} viewBox="0 0 400 200" preserveAspectRatio="none">
              <path d="M0,100 Q50,60 100,80 T200,70 T300,90 T400,60" fill="none" stroke="#c9a227" strokeWidth="1"/>
              <path d="M0,120 Q50,90 100,100 T200,90 T300,110 T400,80" fill="none" stroke="#c9a227" strokeWidth="0.8"/>
              <path d="M0,140 Q50,110 100,120 T200,110 T300,130 T400,100" fill="none" stroke="#c9a227" strokeWidth="0.6"/>
            </svg>
            <div style={{ position: "absolute", top: 12, left: 12, width: 20, height: 20, borderTop: "1px solid var(--gold-dim)", borderLeft: "1px solid var(--gold-dim)" }} />
            <div style={{ position: "absolute", top: 12, right: 12, width: 20, height: 20, borderTop: "1px solid var(--gold-dim)", borderRight: "1px solid var(--gold-dim)" }} />
            <div style={{ position: "absolute", bottom: 12, left: 12, width: 20, height: 20, borderBottom: "1px solid var(--gold-dim)", borderLeft: "1px solid var(--gold-dim)" }} />
            <div style={{ position: "absolute", bottom: 12, right: 12, width: 20, height: 20, borderBottom: "1px solid var(--gold-dim)", borderRight: "1px solid var(--gold-dim)" }} />
            <div style={{
              position: "absolute", top: "50%", left: "50%", transform: "translate(-50%, -50%)",
              display: "flex", flexDirection: "column", alignItems: "center", gap: 6,
            }}>
              <div style={{
                width: 40, height: 40, borderRadius: 2, border: "1px solid var(--gold-dim)",
                background: "rgba(201,162,39,0.06)",
                display: "flex", alignItems: "center", justifyContent: "center",
                fontSize: 20, color: "var(--gold-dim)",
              }}>&#9671;</div>
              {listing.acreage && (
                <span style={{ fontSize: 12, fontFamily: "var(--mono)", color: "var(--gold)", letterSpacing: 2 }}>
                  {listing.acreage} ACRES
                </span>
              )}
            </div>
            <div style={{
              position: "absolute", top: 14, right: 36, padding: "3px 12px", borderRadius: 1,
              background: st.bg, color: st.color, fontSize: 10, fontWeight: 600, letterSpacing: 2,
              textTransform: "uppercase", fontFamily: "var(--mono)", border: "1px solid " + st.border,
            }}>{st.label}</div>
          </div>

          <div style={{ padding: "18px 22px 20px" }}>
            <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 3, color: "var(--gold-dim)", marginBottom: 6 }}>
              {listing.parcelId || "PARCEL"}
            </div>
            <h3 style={{ margin: "0 0 4px", fontSize: 18, fontWeight: 400, fontFamily: "var(--display)", color: "var(--fg)", letterSpacing: 0.5 }}>
              {listing.address || "Untitled Parcel"}
            </h3>
            <p style={{ margin: "0 0 14px", fontSize: 12, color: "var(--muted)", fontFamily: "var(--mono)", letterSpacing: 1 }}>
              {[listing.city, listing.county ? listing.county + " County" : "", listing.state].filter(Boolean).join(", ")}
            </p>
            {listing.description && (
              <p style={{
                margin: "0 0 14px", fontSize: 13, color: "var(--muted)", lineHeight: 1.65, fontFamily: "var(--body)",
                display: "-webkit-box", WebkitLineClamp: 2, WebkitBoxOrient: "vertical", overflow: "hidden",
              }}>{listing.description}</p>
            )}
            {listing.features && listing.features.length > 0 && (
              <div style={{ display: "flex", flexWrap: "wrap", gap: 5, marginBottom: 16 }}>
                {listing.features.slice(0, 4).map(function(f) { return (
                  <span key={f} style={{
                    padding: "3px 9px", borderRadius: 1, fontSize: 10,
                    background: "rgba(201,162,39,0.06)", color: "var(--gold-dim)",
                    fontFamily: "var(--mono)", letterSpacing: 0.8, border: "1px solid rgba(201,162,39,0.1)",
                  }}>{f}</span>
                ); })}
                {listing.features.length > 4 && (
                  <span style={{ padding: "3px 6px", fontSize: 10, color: "var(--gold-dim)", fontFamily: "var(--mono)" }}>
                    +{listing.features.length - 4}
                  </span>
                )}
              </div>
            )}
            <GoldDivider style={{ marginBottom: 14 }} />
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "baseline" }}>
              <div>
                {listing.askingPrice && (
                  <div style={{ fontSize: 24, fontWeight: 400, fontFamily: "var(--display)", color: "var(--gold)", letterSpacing: 1 }}>
                    ${fmt(listing.askingPrice)}
                  </div>
                )}
                {listing.sellerFinance && listing.sfDown && (
                  <div style={{ fontSize: 11, color: "var(--gold-dim)", fontFamily: "var(--mono)", marginTop: 3, letterSpacing: 0.5 }}>
                    ${fmt(listing.sfDown)} down · ${fmt(listing.sfMonthly)}/mo
                  </div>
                )}
              </div>
              {!isPublic && profit !== null && (
                <div style={{ textAlign: "right" }}>
                  <div style={{ fontSize: 10, color: "var(--muted)", fontFamily: "var(--mono)", letterSpacing: 1 }}>PROFIT</div>
                  <div style={{
                    fontSize: 16, fontWeight: 600, fontFamily: "var(--mono)",
                    color: profit > 0 ? "#4ade80" : "#ef4444",
                  }}>{profit >= 0 ? "+" : ""}${fmt(profit)}</div>
                </div>
              )}
            </div>
          </div>
        </div>
      );
    }

    /* ═══ LISTING FORM ═══ */

    function ListingForm({ listing, onSave, onCancel, onDelete }) {
      const [form, setForm] = useState(listing || { ...EMPTY_LISTING });
      const isEdit = !!(listing && listing.id);
      const set = function(k, v) { setForm(function(prev) { return { ...prev, [k]: v }; }); };
      const toggleFeature = function(f) {
        setForm(function(prev) {
          return { ...prev, features: prev.features.includes(f) ? prev.features.filter(function(x) { return x !== f; }) : [...prev.features, f] };
        });
      };

      const inputStyle = {
        width: "100%", padding: "11px 14px", borderRadius: 2,
        border: "1px solid var(--border)", background: "var(--input-bg)",
        color: "var(--fg)", fontSize: 14, fontFamily: "var(--mono)",
        outline: "none", boxSizing: "border-box",
      };
      const labelStyle = {
        fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 2,
        textTransform: "uppercase", color: "var(--gold-dim)", marginBottom: 6, display: "block",
      };

      return (
        <div style={{
          position: "fixed", inset: 0, zIndex: 1000,
          background: "rgba(0,0,0,0.8)", backdropFilter: "blur(10px)",
          display: "flex", alignItems: "flex-start", justifyContent: "center",
          padding: "40px 16px", overflowY: "auto",
        }}>
          <div style={{
            background: "var(--bg)", borderRadius: 2, border: "1px solid var(--border)",
            width: "100%", maxWidth: 600,
            boxShadow: "0 32px 100px rgba(0,0,0,0.6), 0 0 0 1px rgba(201,162,39,0.1)",
          }}>
            <div style={{ height: 3, background: "linear-gradient(90deg, transparent, var(--gold), var(--gold-light), var(--gold), transparent)" }} />
            <div style={{ padding: "28px 28px 24px" }}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 24 }}>
                <div>
                  <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 3, color: "var(--gold-dim)", marginBottom: 4 }}>
                    {isEdit ? "EDIT ASSET" : "NEW ACQUISITION"}
                  </div>
                  <h2 style={{ margin: 0, fontSize: 22, fontWeight: 400, fontFamily: "var(--display)", color: "var(--fg)" }}>
                    {isEdit ? "Edit Listing" : "Add Property"}
                  </h2>
                </div>
                <button onClick={onCancel} style={{
                  background: "none", border: "1px solid var(--border)", color: "var(--muted)",
                  width: 36, height: 36, borderRadius: 2, fontSize: 18, cursor: "pointer",
                  display: "flex", alignItems: "center", justifyContent: "center",
                }}>&times;</button>
              </div>
              <GoldDivider style={{ marginBottom: 24 }} />

              <div style={{ marginBottom: 22 }}>
                <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 2, color: "var(--gold)", marginBottom: 14 }}>PROPERTY DETAILS</div>
                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
                  <div style={{ gridColumn: "1 / -1" }}><label style={labelStyle}>Address</label><input style={inputStyle} value={form.address} onChange={function(e) { set("address", e.target.value); }} placeholder="108 Flores St" /></div>
                  <div><label style={labelStyle}>City</label><input style={inputStyle} value={form.city} onChange={function(e) { set("city", e.target.value); }} placeholder="Del Rio" /></div>
                  <div><label style={labelStyle}>County</label><input style={inputStyle} value={form.county} onChange={function(e) { set("county", e.target.value); }} placeholder="Val Verde" /></div>
                  <div><label style={labelStyle}>State</label><input style={inputStyle} value={form.state} onChange={function(e) { set("state", e.target.value); }} placeholder="TX" /></div>
                  <div><label style={labelStyle}>Parcel ID</label><input style={inputStyle} value={form.parcelId} onChange={function(e) { set("parcelId", e.target.value); }} placeholder="R000-1234-5678" /></div>
                  <div><label style={labelStyle}>Acreage</label><input style={inputStyle} type="number" step="0.01" value={form.acreage} onChange={function(e) { set("acreage", e.target.value); }} placeholder="0.25" /></div>
                  <div><label style={labelStyle}>Date Acquired</label><input style={inputStyle} type="date" value={form.dateAcquired} onChange={function(e) { set("dateAcquired", e.target.value); }} /></div>
                </div>
              </div>

              <div style={{ marginBottom: 22 }}>
                <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 2, color: "var(--gold)", marginBottom: 14 }}>FINANCIALS</div>
                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12 }}>
                  <div><label style={labelStyle}>Purchase Price</label><input style={inputStyle} type="number" value={form.purchasePrice} onChange={function(e) { set("purchasePrice", e.target.value); }} placeholder="500" /></div>
                  <div><label style={labelStyle}>Asking Price</label><input style={inputStyle} type="number" value={form.askingPrice} onChange={function(e) { set("askingPrice", e.target.value); }} placeholder="3000" /></div>
                  <div><label style={labelStyle}>Status</label>
                    <select style={{ ...inputStyle, fontFamily: "var(--body)" }} value={form.status} onChange={function(e) { set("status", e.target.value); }}>
                      {Object.entries(STATUS_MAP).map(function([k, v]) { return <option key={k} value={k}>{v.label}</option>; })}
                    </select>
                  </div>
                </div>
                <div style={{ marginTop: 14 }}>
                  <label style={{ display: "flex", alignItems: "center", gap: 10, cursor: "pointer" }}>
                    <div onClick={function() { set("sellerFinance", !form.sellerFinance); }} style={{
                      width: 40, height: 20, borderRadius: 2, padding: 2,
                      background: form.sellerFinance ? "var(--gold)" : "var(--border)",
                      transition: "background 0.2s", cursor: "pointer", display: "flex", alignItems: "center",
                    }}>
                      <div style={{
                        width: 16, height: 16, borderRadius: 1, background: form.sellerFinance ? "#0d0c08" : "var(--muted)",
                        transform: form.sellerFinance ? "translateX(20px)" : "translateX(0)", transition: "transform 0.2s",
                      }} />
                    </div>
                    <span style={{ fontSize: 12, color: "var(--fg)", fontFamily: "var(--body)" }}>Offer seller financing</span>
                  </label>
                </div>
                {form.sellerFinance && (
                  <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12, marginTop: 12 }}>
                    <div><label style={labelStyle}>Down Payment</label><input style={inputStyle} type="number" value={form.sfDown} onChange={function(e) { set("sfDown", e.target.value); }} placeholder="300" /></div>
                    <div><label style={labelStyle}>Monthly</label><input style={inputStyle} type="number" value={form.sfMonthly} onChange={function(e) { set("sfMonthly", e.target.value); }} placeholder="150" /></div>
                    <div><label style={labelStyle}>Term (months)</label><input style={inputStyle} type="number" value={form.sfTermMonths} onChange={function(e) { set("sfTermMonths", e.target.value); }} placeholder="24" /></div>
                  </div>
                )}
              </div>

              <div style={{ marginBottom: 22 }}>
                <label style={labelStyle}>Description</label>
                <textarea value={form.description} onChange={function(e) { set("description", e.target.value); }}
                  placeholder="Describe the property for potential buyers..."
                  rows={3} style={{ ...inputStyle, resize: "vertical", fontFamily: "var(--body)" }} />
              </div>

              <div style={{ marginBottom: 24 }}>
                <label style={labelStyle}>Property Features</label>
                <div style={{ display: "flex", flexWrap: "wrap", gap: 6, marginTop: 4 }}>
                  {FEATURE_OPTIONS.map(function(f) {
                    const active = form.features.includes(f);
                    return (
                      <button key={f} onClick={function() { toggleFeature(f); }} style={{
                        padding: "6px 14px", borderRadius: 1, fontSize: 11,
                        border: "1px solid " + (active ? "var(--gold)" : "var(--border)"),
                        background: active ? "rgba(201,162,39,0.1)" : "transparent",
                        color: active ? "var(--gold)" : "var(--muted)",
                        cursor: "pointer", fontFamily: "var(--mono)", letterSpacing: 0.5,
                      }}>{f}</button>
                    );
                  })}
                </div>
              </div>

              <GoldDivider style={{ marginBottom: 20 }} />

              <div style={{ display: "flex", justifyContent: "space-between", gap: 10 }}>
                <div>
                  {isEdit && (
                    <button onClick={function() { onDelete(form.id); }} style={{
                      padding: "10px 20px", borderRadius: 2, border: "1px solid rgba(239,68,68,0.3)",
                      background: "rgba(239,68,68,0.06)", color: "#ef4444", fontSize: 13,
                      fontFamily: "var(--mono)", cursor: "pointer", letterSpacing: 1,
                    }}>DELETE</button>
                  )}
                </div>
                <div style={{ display: "flex", gap: 10 }}>
                  <button onClick={onCancel} style={{
                    padding: "10px 22px", borderRadius: 2, border: "1px solid var(--border)",
                    background: "transparent", color: "var(--muted)", fontSize: 13,
                    fontFamily: "var(--mono)", cursor: "pointer", letterSpacing: 1,
                  }}>CANCEL</button>
                  <button onClick={function() { onSave(form); }} style={{
                    padding: "10px 28px", borderRadius: 2, border: "none",
                    background: "linear-gradient(135deg, var(--gold), var(--gold-light))",
                    color: "#0d0c08", fontSize: 13, fontFamily: "var(--mono)",
                    cursor: "pointer", fontWeight: 600, letterSpacing: 1,
                  }}>{isEdit ? "SAVE" : "ADD LISTING"}</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      );
    }

    /* ═══ ADMIN LOGIN ═══ */

    function AdminLogin({ onLogin }) {
      const [pass, setPass] = useState("");
      const [error, setError] = useState(false);

      const handleLogin = function() {
        const stored = localStorage.getItem("sukup-admin-pass");
        if (!stored) { localStorage.setItem("sukup-admin-pass", pass); onLogin(); }
        else if (pass === stored) { onLogin(); }
        else { setError(true); setTimeout(function() { setError(false); }, 2000); }
      };

      const isFirstTime = !localStorage.getItem("sukup-admin-pass");

      return (
        <div style={{
          position: "fixed", inset: 0, zIndex: 1000,
          background: "rgba(0,0,0,0.85)", backdropFilter: "blur(12px)",
          display: "flex", alignItems: "center", justifyContent: "center",
        }}>
          <div style={{
            background: "var(--bg)", borderRadius: 2, border: "1px solid var(--border)",
            width: "100%", maxWidth: 400,
            boxShadow: "0 32px 100px rgba(0,0,0,0.6), 0 0 0 1px rgba(201,162,39,0.1)",
          }}>
            <div style={{ height: 3, background: "linear-gradient(90deg, transparent, var(--gold), var(--gold-light), var(--gold), transparent)" }} />
            <div style={{ padding: "40px 32px", textAlign: "center" }}>
              <div style={{
                width: 56, height: 56, borderRadius: 2, margin: "0 auto 20px",
                border: "1px solid var(--gold-dim)", background: "rgba(201,162,39,0.04)",
                display: "flex", alignItems: "center", justifyContent: "center",
                fontSize: 20, fontFamily: "var(--mono)", color: "var(--gold)",
              }}>&#9672;</div>
              <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 4, color: "var(--gold-dim)", marginBottom: 6 }}>
                {isFirstTime ? "INITIALIZE" : "CLASSIFIED ACCESS"}
              </div>
              <h2 style={{ margin: "0 0 24px", fontSize: 22, fontWeight: 400, fontFamily: "var(--display)", color: "var(--fg)" }}>
                {isFirstTime ? "Set Your Password" : "Authentication Required"}
              </h2>
              <input
                type="password" value={pass} onChange={function(e) { setPass(e.target.value); }}
                onKeyDown={function(e) { if (e.key === "Enter") handleLogin(); }}
                placeholder="Enter password"
                style={{
                  width: "100%", padding: "13px 16px", borderRadius: 2,
                  border: "1px solid " + (error ? "#ef4444" : "var(--border)"),
                  background: "var(--input-bg)", color: "var(--fg)", fontSize: 15,
                  fontFamily: "var(--mono)", outline: "none", boxSizing: "border-box",
                  marginBottom: 16, textAlign: "center", letterSpacing: 4,
                }}
              />
              {error && <p style={{ color: "#ef4444", fontSize: 12, margin: "0 0 12px", fontFamily: "var(--mono)", letterSpacing: 1 }}>ACCESS DENIED</p>}
              <button onClick={handleLogin} style={{
                width: "100%", padding: "13px", borderRadius: 2, border: "none",
                background: "linear-gradient(135deg, var(--gold), var(--gold-light))",
                color: "#0d0c08", fontSize: 13, fontWeight: 600, cursor: "pointer",
                fontFamily: "var(--mono)", letterSpacing: 2,
              }}>{isFirstTime ? "INITIALIZE" : "AUTHENTICATE"}</button>
            </div>
          </div>
        </div>
      );
    }

    /* ═══ DEAL ANALYZER ═══ */

    const CHECKLIST_ITEMS = [
      { category: "Tax & Financial", icon: "\u{1F4B0}", items: [
        { id: "back_taxes", label: "Check for delinquent/back taxes", detail: "Call county Tax Assessor-Collector or check online portal. Get exact amount owed." },
        { id: "tax_liens", label: "Check for tax liens or tax sale history", detail: "Ask the tax office if a tax lien has been sold to a third party." },
        { id: "current_taxes", label: "Verify current year tax amount", detail: "Confirm current amount and proration at closing." },
        { id: "special_assess", label: "Check for special assessments or fees", detail: "HOA dues, utility district assessments, road maintenance fees, etc." },
      ]},
      { category: "Title & Ownership", icon: "\u{1F4DC}", items: [
        { id: "owner_verify", label: "Verify seller is the legal owner", detail: "Compare seller ID to name on deed in county records." },
        { id: "title_search", label: "Run a title search", detail: "Use a local title company ($150-$300). Confirms clean chain of title." },
        { id: "liens_judgments", label: "Check for liens and judgments", detail: "Mechanic's liens, court judgments, IRS liens, mortgage liens." },
        { id: "deed_description", label: "Verify legal description matches", detail: "Compare deed legal description to appraisal district records." },
      ]},
      { category: "Physical & Access", icon: "\u{1F5FA}\u{FE0F}", items: [
        { id: "road_access", label: "Confirm legal road access", detail: "Verify road frontage or recorded easement. Landlocked = no resale." },
        { id: "flood_zone", label: "Check FEMA flood zone status", detail: "Free at fema.gov/flood-maps." },
        { id: "utilities", label: "Check utility availability", detail: "Water, sewer, electric at lot line?" },
        { id: "zoning", label: "Verify zoning and building restrictions", detail: "Check with local planning dept." },
        { id: "deed_restrictions", label: "Check deed restrictions/covenants", detail: "Restrictions on structure types, mobile homes, min build sizes." },
        { id: "physical_visit", label: "Drive by or view on Google Maps", detail: "Confirm lot exists, isn't a drainage ditch, isn't occupied." },
      ]},
      { category: "Deal Math", icon: "\u{1F9EE}", items: [
        { id: "comps_check", label: "Run comparable sales analysis", detail: "Use the Comps section above." },
        { id: "total_cost", label: "Calculate total acquisition cost", detail: "Purchase + back taxes + title + recording fees." },
        { id: "profit_margin", label: "Verify minimum 2x profit target", detail: "Total cost should be no more than 50% of realistic resale value." },
      ]},
    ];

    function DealAnalyzerTab() {
      const [parcelCode, setParcelCode] = useState("");
      const [parcelAcreage, setParcelAcreage] = useState("");
      const [assessedValue, setAssessedValue] = useState("");
      const [checked, setChecked] = useState({});
      const [notes, setNotes] = useState({});
      const [expandedItem, setExpandedItem] = useState(null);
      const [comps, setComps] = useState([
        { address: "", soldPrice: "", acreage: "", daysOnMarket: "" },
        { address: "", soldPrice: "", acreage: "", daysOnMarket: "" },
        { address: "", soldPrice: "", acreage: "", daysOnMarket: "" },
      ]);
      const [offerPct, setOfferPct] = useState(25);
      const [backTaxes, setBackTaxes] = useState("");
      const [closingCosts, setClosingCosts] = useState("500");
      const [showChecklist, setShowChecklist] = useState(false);

      useEffect(function() {
        try {
          var raw = localStorage.getItem(ANALYZER_KEY);
          if (raw) {
            var d = JSON.parse(raw);
            if (d.parcelCode) setParcelCode(d.parcelCode);
            if (d.parcelAcreage) setParcelAcreage(d.parcelAcreage);
            if (d.assessedValue) setAssessedValue(d.assessedValue);
            if (d.comps) setComps(d.comps);
            if (d.offerPct) setOfferPct(d.offerPct);
            if (d.backTaxes) setBackTaxes(d.backTaxes);
            if (d.closingCosts) setClosingCosts(d.closingCosts);
            if (d.checked) setChecked(d.checked);
            if (d.notes) setNotes(d.notes);
          }
        } catch(e) {}
      }, []);

      useEffect(function() {
        try {
          localStorage.setItem(ANALYZER_KEY, JSON.stringify({
            parcelCode, parcelAcreage, assessedValue, comps, offerPct, backTaxes, closingCosts, checked, notes
          }));
        } catch(e) {}
      }, [parcelCode, parcelAcreage, assessedValue, comps, offerPct, backTaxes, closingCosts, checked, notes]);

      var clearAll = function() {
        setParcelCode(""); setParcelAcreage(""); setAssessedValue("");
        setChecked({}); setNotes({});
        setComps([{ address: "", soldPrice: "", acreage: "", daysOnMarket: "" }, { address: "", soldPrice: "", acreage: "", daysOnMarket: "" }, { address: "", soldPrice: "", acreage: "", daysOnMarket: "" }]);
        setOfferPct(25); setBackTaxes(""); setClosingCosts("500");
        try { localStorage.removeItem(ANALYZER_KEY); } catch(e) {}
      };

      var addComp = function() { setComps([...comps, { address: "", soldPrice: "", acreage: "", daysOnMarket: "" }]); };
      var updateComp = function(i, field, val) { var c = [...comps]; c[i] = { ...c[i], [field]: val }; setComps(c); };
      var removeComp = function(i) { if (comps.length > 1) setComps(comps.filter(function(_, idx) { return idx !== i; })); };

      var validComps = comps.filter(function(c) { return parseFloat(c.soldPrice) > 0; });
      var avgSoldPrice = validComps.length > 0 ? validComps.reduce(function(s, c) { return s + parseFloat(c.soldPrice); }, 0) / validComps.length : 0;
      var compsWithAcres = validComps.filter(function(c) { return parseFloat(c.acreage) > 0; });
      var avgPricePerAcre = compsWithAcres.length > 0 ? compsWithAcres.reduce(function(s, c) { return s + parseFloat(c.soldPrice) / parseFloat(c.acreage); }, 0) / compsWithAcres.length : 0;
      var compsWithDOM = validComps.filter(function(c) { return parseInt(c.daysOnMarket) > 0; });
      var avgDOM = compsWithDOM.length > 0 ? Math.round(compsWithDOM.reduce(function(s, c) { return s + parseInt(c.daysOnMarket); }, 0) / compsWithDOM.length) : 0;

      var estimatedMarketValue = parseFloat(parcelAcreage) > 0 && avgPricePerAcre > 0 ? avgPricePerAcre * parseFloat(parcelAcreage) : avgSoldPrice;
      var yourOffer = estimatedMarketValue * (offerPct / 100);
      var totalCost = yourOffer + (parseFloat(backTaxes) || 0) + (parseFloat(closingCosts) || 0);
      var cashProfit = estimatedMarketValue - totalCost;
      var roi = totalCost > 0 ? ((cashProfit / totalCost) * 100).toFixed(0) : 0;
      var sfDown = Math.round(estimatedMarketValue * 0.1);
      var sfMonthly = Math.round((estimatedMarketValue * 1.3 - sfDown) / 24);
      var sfTotal = sfDown + sfMonthly * 24;
      var sfProfit = sfTotal - totalCost;

      var risks = [];
      if (totalCost > 0 && totalCost < 800) risks.push("Total cost under $800 — closing costs may destroy margin");
      if (parseFloat(backTaxes) > yourOffer * 0.5) risks.push("Back taxes exceed 50% of offer — verify with county");
      if (roi < 100 && validComps.length > 0) risks.push("ROI under 100% — below 2x target");
      if (validComps.length === 1) risks.push("Only 1 comp — need 2+ for confidence");

      var total = CHECKLIST_ITEMS.reduce(function(sum, cat) { return sum + cat.items.length; }, 0);
      var done = Object.values(checked).filter(Boolean).length;
      var pct = Math.round((done / total) * 100);

      var inputStyle = {
        width: "100%", padding: "10px 12px", borderRadius: 2,
        border: "1px solid var(--border)", background: "var(--input-bg)",
        color: "var(--fg)", fontSize: 14, fontFamily: "var(--mono)",
        outline: "none", boxSizing: "border-box",
      };
      var labelStyle = {
        fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 2,
        textTransform: "uppercase", color: "var(--gold-dim)", marginBottom: 5, display: "block",
      };

      return (
        <div style={{ animation: "fadeIn 0.4s ease" }}>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 24 }}>
            <div>
              <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 4, color: "var(--gold-dim)", marginBottom: 4 }}>DEAL ANALYZER</div>
              <div style={{ fontSize: 20, fontFamily: "var(--display)", color: "var(--fg)" }}>{parcelCode || "New Analysis"}</div>
            </div>
            <button onClick={clearAll} style={{
              padding: "8px 16px", borderRadius: 2, border: "1px solid rgba(239,68,68,0.3)",
              background: "rgba(239,68,68,0.06)", color: "#ef4444", fontSize: 11,
              fontFamily: "var(--mono)", cursor: "pointer", letterSpacing: 1,
            }}>CLEAR ALL</button>
          </div>

          {/* Subject Property */}
          <div style={{ background: "var(--card)", borderRadius: 2, border: "1px solid var(--border)", padding: 20, marginBottom: 20 }}>
            <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 2, color: "var(--gold)", marginBottom: 14 }}>SUBJECT PROPERTY</div>
            <div style={{ display: "grid", gridTemplateColumns: "2fr 1fr 1fr", gap: 12 }}>
              <div>
                <label style={labelStyle}>Parcel ID / Code</label>
                <input style={{ ...inputStyle, fontSize: 16, fontWeight: 600 }} placeholder="R000-1234-5678" value={parcelCode} onChange={function(e) { setParcelCode(e.target.value); }} />
              </div>
              <div>
                <label style={labelStyle}>Acreage</label>
                <input style={inputStyle} type="number" step="0.01" placeholder="0.25" value={parcelAcreage} onChange={function(e) { setParcelAcreage(e.target.value); }} />
              </div>
              <div>
                <label style={labelStyle}>Assessed Value ($)</label>
                <input style={inputStyle} type="number" placeholder="3000" value={assessedValue} onChange={function(e) { setAssessedValue(e.target.value); }} />
              </div>
            </div>
          </div>

          {/* Comps */}
          <div style={{ background: "var(--card)", borderRadius: 2, border: "1px solid var(--border)", padding: 20, marginBottom: 20 }}>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 14 }}>
              <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 2, color: "var(--gold)" }}>COMPARABLE SALES (SOLD ONLY)</div>
              <button onClick={addComp} style={{
                padding: "5px 14px", borderRadius: 2, border: "1px dashed var(--gold-dim)",
                background: "transparent", color: "var(--gold)", fontSize: 11,
                fontFamily: "var(--mono)", cursor: "pointer",
              }}>+ ADD COMP</button>
            </div>
            <div style={{ fontSize: 11, color: "var(--muted)", fontFamily: "var(--body)", marginBottom: 14, lineHeight: 1.5, fontStyle: "italic" }}>
              Use sold comps only — not Zillow asking prices. Check county deed records, LandWatch sold listings, or Lands of America.
            </div>
            {comps.map(function(comp, i) {
              return (
                <div key={i} style={{ display: "grid", gridTemplateColumns: "2fr 1fr 1fr 1fr 32px", gap: 8, marginBottom: 8, alignItems: "end" }}>
                  <div>
                    {i === 0 && <label style={labelStyle}>Address / Description</label>}
                    <input style={inputStyle} placeholder="Nearby sold parcel" value={comp.address} onChange={function(e) { updateComp(i, "address", e.target.value); }} />
                  </div>
                  <div>
                    {i === 0 && <label style={labelStyle}>Sold Price ($)</label>}
                    <input style={inputStyle} type="number" placeholder="2500" value={comp.soldPrice} onChange={function(e) { updateComp(i, "soldPrice", e.target.value); }} />
                  </div>
                  <div>
                    {i === 0 && <label style={labelStyle}>Acres</label>}
                    <input style={inputStyle} type="number" step="0.01" placeholder="0.25" value={comp.acreage} onChange={function(e) { updateComp(i, "acreage", e.target.value); }} />
                  </div>
                  <div>
                    {i === 0 && <label style={labelStyle}>Days on Mkt</label>}
                    <input style={inputStyle} type="number" placeholder="45" value={comp.daysOnMarket} onChange={function(e) { updateComp(i, "daysOnMarket", e.target.value); }} />
                  </div>
                  <button onClick={function() { removeComp(i); }} style={{
                    width: 32, height: 38, borderRadius: 2, border: "1px solid var(--border)",
                    background: "transparent", color: "var(--muted)", cursor: comps.length > 1 ? "pointer" : "default",
                    opacity: comps.length > 1 ? 1 : 0.3, fontSize: 16,
                  }}>&times;</button>
                </div>
              );
            })}
          </div>

          {/* Offer Calculator */}
          <div style={{ background: "var(--card)", borderRadius: 2, border: "1px solid var(--border)", padding: 20, marginBottom: 20 }}>
            <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 2, color: "var(--gold)", marginBottom: 14 }}>OFFER CALCULATOR</div>
            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12 }}>
              <div>
                <label style={labelStyle}>Offer % of Market Value</label>
                <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                  <input type="range" min="10" max="50" value={offerPct} onChange={function(e) { setOfferPct(parseInt(e.target.value)); }} style={{ flex: 1 }} />
                  <span style={{ fontFamily: "var(--mono)", fontSize: 16, fontWeight: 600, color: "var(--gold)", minWidth: 42 }}>{offerPct}%</span>
                </div>
              </div>
              <div>
                <label style={labelStyle}>Back Taxes Owed ($)</label>
                <input style={inputStyle} type="number" placeholder="0" value={backTaxes} onChange={function(e) { setBackTaxes(e.target.value); }} />
              </div>
              <div>
                <label style={labelStyle}>Closing / Title ($)</label>
                <input style={inputStyle} type="number" placeholder="500" value={closingCosts} onChange={function(e) { setClosingCosts(e.target.value); }} />
              </div>
            </div>
          </div>

          {/* Risk Flags */}
          {risks.length > 0 && (
            <div style={{ background: "rgba(239,68,68,0.06)", border: "1px solid rgba(239,68,68,0.2)", borderRadius: 2, padding: "14px 18px", marginBottom: 20 }}>
              <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 2, color: "#ef4444", marginBottom: 8 }}>RISK FLAGS</div>
              {risks.map(function(r, i) { return <div key={i} style={{ fontSize: 13, color: "#ef4444", fontFamily: "var(--body)", marginBottom: 4 }}>{r}</div>; })}
            </div>
          )}

          {/* Results */}
          {validComps.length > 0 && (
            <div style={{ background: "var(--card)", borderRadius: 2, border: "1px solid var(--border)", overflow: "hidden", marginBottom: 20 }}>
              <div style={{ padding: "16px 20px 12px", borderBottom: "1px solid var(--border)" }}>
                <span style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 3, color: "var(--gold-dim)" }}>DEAL ANALYSIS</span>
              </div>
              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", borderBottom: "1px solid var(--border)" }}>
                {[
                  { label: "Avg Comp Sale", value: "$" + fmt(avgSoldPrice) },
                  { label: "$/Acre", value: "$" + fmt(avgPricePerAcre) },
                  { label: "Avg Days on Mkt", value: avgDOM || "\u2014" },
                ].map(function(s, i) {
                  return (
                    <div key={s.label} style={{ padding: "14px 18px", borderRight: i < 2 ? "1px solid var(--border)" : "none" }}>
                      <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 1.5, textTransform: "uppercase", color: "var(--muted)", marginBottom: 4 }}>{s.label}</div>
                      <div style={{ fontSize: 22, fontWeight: 400, fontFamily: "var(--display)", color: "var(--fg)" }}>{s.value}</div>
                    </div>
                  );
                })}
              </div>
              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", borderBottom: "1px solid var(--border)" }}>
                <div style={{ padding: "14px 18px", borderRight: "1px solid var(--border)" }}>
                  <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 1.5, textTransform: "uppercase", color: "var(--muted)", marginBottom: 4 }}>Est. Market Value</div>
                  <div style={{ fontSize: 26, fontWeight: 400, fontFamily: "var(--display)", color: "var(--gold)" }}>${fmt(estimatedMarketValue)}</div>
                </div>
                <div style={{ padding: "14px 18px" }}>
                  <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 1.5, textTransform: "uppercase", color: "var(--muted)", marginBottom: 4 }}>Your Offer ({offerPct}%)</div>
                  <div style={{ fontSize: 26, fontWeight: 400, fontFamily: "var(--display)", color: "var(--fg)" }}>${fmt(yourOffer)}</div>
                </div>
              </div>
              <div style={{ padding: 18 }}>
                <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 2, textTransform: "uppercase", color: "var(--muted)", marginBottom: 14 }}>EXIT SCENARIOS</div>
                <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", padding: "12px 16px", borderRadius: 2, background: "var(--bg)", marginBottom: 8, border: "1px solid var(--border)" }}>
                  <div>
                    <div style={{ fontSize: 14, fontWeight: 600, fontFamily: "var(--display)", color: "var(--fg)" }}>Cash Flip</div>
                    <div style={{ fontSize: 12, color: "var(--muted)", fontFamily: "var(--mono)" }}>Total cost: ${fmt(totalCost)}</div>
                  </div>
                  <div style={{ textAlign: "right" }}>
                    <div style={{ fontSize: 20, fontWeight: 600, fontFamily: "var(--mono)", color: cashProfit > 0 ? "#4ade80" : "#ef4444" }}>
                      {cashProfit >= 0 ? "+" : ""}${fmt(cashProfit)}
                    </div>
                    <div style={{ fontSize: 12, fontFamily: "var(--mono)", color: roi > 0 ? "#4ade80" : "#ef4444" }}>{roi}% ROI</div>
                  </div>
                </div>
                <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", padding: "12px 16px", borderRadius: 2, background: "var(--bg)", border: "1px solid var(--border)" }}>
                  <div>
                    <div style={{ fontSize: 14, fontWeight: 600, fontFamily: "var(--display)", color: "var(--fg)" }}>Seller Finance</div>
                    <div style={{ fontSize: 12, color: "var(--muted)", fontFamily: "var(--mono)" }}>${fmt(sfDown)} down + ${fmt(sfMonthly)}/mo x 24mo</div>
                  </div>
                  <div style={{ textAlign: "right" }}>
                    <div style={{ fontSize: 20, fontWeight: 600, fontFamily: "var(--mono)", color: sfProfit > 0 ? "#4ade80" : "#ef4444" }}>
                      {sfProfit >= 0 ? "+" : ""}${fmt(sfProfit)}
                    </div>
                    <div style={{ fontSize: 12, fontFamily: "var(--mono)", color: "var(--muted)" }}>over 24 months</div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {validComps.length === 0 && (
            <div style={{ padding: 28, borderRadius: 2, border: "1px dashed var(--border)", textAlign: "center", color: "var(--muted)", fontSize: 14, fontFamily: "var(--body)", marginBottom: 20 }}>
              Enter at least one comparable sale above to see your deal analysis.
            </div>
          )}

          {/* Due Diligence Checklist */}
          <div style={{ background: "var(--card)", borderRadius: 2, border: "1px solid var(--border)", overflow: "hidden" }}>
            <div onClick={function() { setShowChecklist(!showChecklist); }}
              style={{ padding: "16px 20px", cursor: "pointer", display: "flex", justifyContent: "space-between", alignItems: "center" }}>
              <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
                <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 2, color: "var(--gold)" }}>DUE DILIGENCE CHECKLIST</div>
                <span style={{ fontSize: 12, fontFamily: "var(--mono)", color: pct === 100 ? "#4ade80" : "var(--gold-dim)" }}>{done}/{total}</span>
              </div>
              <span style={{ fontSize: 12, color: "var(--muted)", transform: showChecklist ? "rotate(180deg)" : "rotate(0)", transition: "transform 0.2s" }}>{"\u25BC"}</span>
            </div>
            {showChecklist && (
              <div style={{ padding: "0 20px 20px" }}>
                <div style={{ height: 6, borderRadius: 3, background: "var(--border)", overflow: "hidden", marginBottom: 20 }}>
                  <div style={{ height: "100%", width: pct + "%", borderRadius: 3, background: pct === 100 ? "#4ade80" : "var(--gold)", transition: "width 0.4s ease" }} />
                </div>
                {CHECKLIST_ITEMS.map(function(cat) {
                  return (
                    <div key={cat.category} style={{ marginBottom: 20 }}>
                      <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 10 }}>
                        <span style={{ fontSize: 16 }}>{cat.icon}</span>
                        <span style={{ fontSize: 13, fontWeight: 600, fontFamily: "var(--display)", color: "var(--fg)" }}>{cat.category}</span>
                      </div>
                      {cat.items.map(function(item) {
                        var isExp = expandedItem === item.id;
                        return (
                          <div key={item.id} style={{
                            marginBottom: 4, borderRadius: 2,
                            border: "1px solid " + (checked[item.id] ? "rgba(74,222,128,0.3)" : "var(--border)"),
                            background: checked[item.id] ? "rgba(74,222,128,0.04)" : "var(--bg)", overflow: "hidden",
                          }}>
                            <div style={{ display: "flex", alignItems: "center", gap: 10, padding: "8px 12px", cursor: "pointer" }}
                              onClick={function() { setExpandedItem(isExp ? null : item.id); }}>
                              <div onClick={function(e) { e.stopPropagation(); setChecked(function(p) { return { ...p, [item.id]: !p[item.id] }; }); }}
                                style={{
                                  width: 20, height: 20, borderRadius: 2, flexShrink: 0, cursor: "pointer",
                                  border: "2px solid " + (checked[item.id] ? "#4ade80" : "var(--border)"),
                                  background: checked[item.id] ? "#4ade80" : "transparent",
                                  display: "flex", alignItems: "center", justifyContent: "center",
                                }}>
                                {checked[item.id] && <span style={{ color: "#0d0c08", fontSize: 12, fontWeight: 700 }}>{"\u2713"}</span>}
                              </div>
                              <span style={{
                                flex: 1, fontSize: 13, fontFamily: "var(--body)",
                                color: checked[item.id] ? "var(--muted)" : "var(--fg)",
                                textDecoration: checked[item.id] ? "line-through" : "none",
                              }}>{item.label}</span>
                              <span style={{ fontSize: 10, color: "var(--muted)", transform: isExp ? "rotate(180deg)" : "rotate(0)", transition: "transform 0.2s" }}>{"\u25BC"}</span>
                            </div>
                            {isExp && (
                              <div style={{ padding: "0 12px 10px 42px" }}>
                                <p style={{ fontSize: 12, color: "var(--muted)", lineHeight: 1.5, margin: "0 0 6px" }}>{item.detail}</p>
                                <textarea placeholder="Notes..." value={notes[item.id] || ""}
                                  onChange={function(e) { setNotes(function(p) { return { ...p, [item.id]: e.target.value }; }); }}
                                  style={{ ...inputStyle, minHeight: 40, resize: "vertical", fontSize: 12 }} />
                              </div>
                            )}
                          </div>
                        );
                      })}
                    </div>
                  );
                })}
              </div>
            )}
          </div>
        </div>
      );
    }

    /* ═══ CAPITAL LEDGER ═══ */

    function CapitalLedgerTab() {
      var DEFAULT_ENTRIES = [{ id: 1, date: "2026-04-09", type: "in", amount: 200, desc: "Investor #1 deposit" }];
      var [entries, setEntries] = useState(DEFAULT_ENTRIES);
      var [form, setForm] = useState({ type: "in", amount: "", desc: "", date: new Date().toISOString().slice(0, 10) });
      var [loaded, setLoaded] = useState(false);
      var [nextId, setNextId] = useState(2);

      useEffect(function() {
        try {
          var raw = localStorage.getItem(LEDGER_KEY);
          if (raw) { var p = JSON.parse(raw); setEntries(p.entries || DEFAULT_ENTRIES); setNextId(p.nextId || 2); }
        } catch(e) {}
        setLoaded(true);
      }, []);

      var save = function(ne, nn) { try { localStorage.setItem(LEDGER_KEY, JSON.stringify({ entries: ne, nextId: nn })); } catch(e) {} };

      var sorted = [...entries].sort(function(a, b) { return a.date.localeCompare(b.date) || a.id - b.id; });
      var bal = 0;
      var rows = sorted.map(function(e) { bal += e.type === "in" ? e.amount : -e.amount; return { ...e, bal: bal }; });

      var totalIn = entries.filter(function(e) { return e.type === "in"; }).reduce(function(s, e) { return s + e.amount; }, 0);
      var totalOut = entries.filter(function(e) { return e.type === "out"; }).reduce(function(s, e) { return s + e.amount; }, 0);
      var balance = totalIn - totalOut;

      var addEntry = function() {
        var amt = parseFloat(form.amount);
        if (!amt || amt <= 0) return;
        var ne = { id: nextId, date: form.date || new Date().toISOString().slice(0, 10), type: form.type, amount: Math.round(amt * 100) / 100, desc: form.desc || (form.type === "in" ? "Deposit" : "Withdrawal") };
        var newEntries = [...entries, ne]; var nn = nextId + 1;
        setEntries(newEntries); setNextId(nn);
        setForm({ ...form, amount: "", desc: "" });
        save(newEntries, nn);
      };

      var delEntry = function(id) { var ne = entries.filter(function(e) { return e.id !== id; }); setEntries(ne); save(ne, nextId); };
      var handleKey = function(e) { if (e.key === "Enter") addEntry(); };

      var inputStyle = {
        height: 40, padding: "0 12px", borderRadius: 2,
        border: "1px solid var(--border)", background: "var(--input-bg)",
        color: "var(--fg)", fontSize: 14, fontFamily: "var(--mono)",
        outline: "none", boxSizing: "border-box",
      };

      if (!loaded) return <div style={{ padding: 40, textAlign: "center", color: "var(--muted)" }}>Loading ledger...</div>;

      return (
        <div style={{ animation: "fadeIn 0.4s ease" }}>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 24 }}>
            <div>
              <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 4, color: "var(--gold-dim)", marginBottom: 4 }}>CAPITAL LEDGER</div>
              <div style={{ fontSize: 20, fontFamily: "var(--display)", color: "var(--fg)" }}>Sukup Capital Partners</div>
            </div>
            <span style={{ fontSize: 12, color: "var(--muted)", fontFamily: "var(--mono)" }}>{entries.length} entries</span>
          </div>

          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12, marginBottom: 24 }}>
            {[
              { label: "Current Balance", value: "$" + fmt2(balance), color: "var(--fg)" },
              { label: "Total Deposits", value: "$" + fmt2(totalIn), color: "#4ade80" },
              { label: "Total Withdrawals", value: "$" + fmt2(totalOut), color: "#ef4444" },
            ].map(function(s) {
              return (
                <div key={s.label} style={{ background: "var(--card)", borderRadius: 2, padding: "16px 18px", border: "1px solid var(--border)" }}>
                  <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 1.5, textTransform: "uppercase", color: "var(--muted)", marginBottom: 6 }}>{s.label}</div>
                  <div style={{ fontSize: 22, fontWeight: 400, fontFamily: "var(--display)", color: s.color }}>{s.value}</div>
                </div>
              );
            })}
          </div>

          <div style={{ display: "flex", gap: 8, marginBottom: 24, alignItems: "end", flexWrap: "wrap" }}>
            <div style={{ display: "flex", flexDirection: "column", gap: 4, width: 110 }}>
              <label style={{ fontSize: 10, fontFamily: "var(--mono)", color: "var(--gold-dim)", letterSpacing: 1, textTransform: "uppercase" }}>Type</label>
              <select value={form.type} onChange={function(e) { setForm({ ...form, type: e.target.value }); }} style={{ ...inputStyle, fontFamily: "var(--body)" }}>
                <option value="in">Deposit</option>
                <option value="out">Withdrawal</option>
              </select>
            </div>
            <div style={{ display: "flex", flexDirection: "column", gap: 4, width: 110 }}>
              <label style={{ fontSize: 10, fontFamily: "var(--mono)", color: "var(--gold-dim)", letterSpacing: 1, textTransform: "uppercase" }}>Amount ($)</label>
              <input type="number" min="0" step="0.01" placeholder="0.00" value={form.amount} onChange={function(e) { setForm({ ...form, amount: e.target.value }); }} onKeyDown={handleKey} style={inputStyle} />
            </div>
            <div style={{ display: "flex", flexDirection: "column", gap: 4, flex: 1, minWidth: 140 }}>
              <label style={{ fontSize: 10, fontFamily: "var(--mono)", color: "var(--gold-dim)", letterSpacing: 1, textTransform: "uppercase" }}>Description</label>
              <input placeholder="e.g. Mailer printing" value={form.desc} onChange={function(e) { setForm({ ...form, desc: e.target.value }); }} onKeyDown={handleKey} style={{ ...inputStyle, fontFamily: "var(--body)" }} />
            </div>
            <div style={{ display: "flex", flexDirection: "column", gap: 4, width: 140 }}>
              <label style={{ fontSize: 10, fontFamily: "var(--mono)", color: "var(--gold-dim)", letterSpacing: 1, textTransform: "uppercase" }}>Date</label>
              <input type="date" value={form.date} onChange={function(e) { setForm({ ...form, date: e.target.value }); }} style={inputStyle} />
            </div>
            <button onClick={addEntry} style={{
              height: 40, padding: "0 20px", borderRadius: 2, border: "none",
              background: "linear-gradient(135deg, var(--gold), var(--gold-light))",
              color: "#0d0c08", fontSize: 13, fontWeight: 600, cursor: "pointer",
              fontFamily: "var(--mono)", letterSpacing: 1, whiteSpace: "nowrap",
              opacity: form.amount ? 1 : 0.5,
            }}>+ ADD</button>
          </div>

          <div style={{ background: "var(--card)", borderRadius: 2, border: "1px solid var(--border)", overflow: "hidden" }}>
            <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 14 }}>
              <thead>
                <tr style={{ borderBottom: "1px solid var(--border)" }}>
                  {["Date", "Description", "Amount", "Balance", ""].map(function(h, i) {
                    return <th key={h || "x"} style={{ textAlign: i >= 2 && i <= 3 ? "right" : "left", padding: "12px 16px", fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 1.5, textTransform: "uppercase", color: "var(--muted)", fontWeight: 500 }}>{h}</th>;
                  })}
                </tr>
              </thead>
              <tbody>
                {rows.length === 0 && <tr><td colSpan={5} style={{ textAlign: "center", padding: "32px 16px", color: "var(--muted)" }}>No entries yet</td></tr>}
                {rows.map(function(r, i) {
                  return (
                    <tr key={r.id} style={{ borderBottom: i < rows.length - 1 ? "1px solid var(--border)" : "none" }}>
                      <td style={{ padding: "10px 16px", fontFamily: "var(--mono)", fontSize: 13, color: "var(--muted)", whiteSpace: "nowrap" }}>{r.date}</td>
                      <td style={{ padding: "10px 16px", fontFamily: "var(--body)" }}>{r.desc}</td>
                      <td style={{ padding: "10px 16px", textAlign: "right", fontFamily: "var(--mono)", fontWeight: 500, color: r.type === "in" ? "#4ade80" : "#ef4444" }}>
                        {r.type === "in" ? "+" : "-"}${fmt2(r.amount)}
                      </td>
                      <td style={{ padding: "10px 16px", textAlign: "right", fontFamily: "var(--mono)", fontWeight: 500 }}>${fmt2(r.bal)}</td>
                      <td style={{ padding: "10px 16px", width: 36 }}>
                        <button onClick={function() { delEntry(r.id); }} style={{ background: "none", border: "none", color: "var(--muted)", cursor: "pointer", fontSize: 18, padding: "2px 6px", borderRadius: 2, lineHeight: 1 }}>&times;</button>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>
      );
    }

    /* ═══ MAIN APP ═══ */

    function SukupListings() {
      const [data, setData] = useState(function() { return loadData(); });
      const [editing, setEditing] = useState(null);
      const [view, setView] = useState("public");
      const [filter, setFilter] = useState("all");
      const [isAdmin, setIsAdmin] = useState(false);
      const [showLogin, setShowLogin] = useState(false);
      const [adminTab, setAdminTab] = useState("listings");

      const listings = data.listings;
      const nextId = data.nextId;

      useEffect(function() { if (sessionStorage.getItem(ADMIN_KEY) === "true") setIsAdmin(true); }, []);

      const handleAdminLogin = function() {
        setIsAdmin(true); setShowLogin(false); setView("manage");
        sessionStorage.setItem(ADMIN_KEY, "true");
      };

      const handleSave = function(form) {
        let newListings, newNext = nextId;
        if (form.id) { newListings = listings.map(function(l) { return l.id === form.id ? form : l; }); }
        else { newListings = [...listings, { ...form, id: nextId }]; newNext = nextId + 1; }
        const newData = { listings: newListings, nextId: newNext };
        setData(newData); setEditing(null); saveData(newData);
      };

      const handleDelete = function(id) {
        const newData = { listings: listings.filter(function(l) { return l.id !== id; }), nextId: nextId };
        setData(newData); setEditing(null); saveData(newData);
      };

      const filtered = filter === "all" ? listings : listings.filter(function(l) { return l.status === filter; });
      const publicListings = listings.filter(function(l) { return l.status === "available" || l.status === "pending"; });

      const totalInvested = listings.reduce(function(s, l) { return s + (Number(l.purchasePrice) || 0); }, 0);
      const totalAsking = listings.filter(function(l) { return l.status !== "sold"; }).reduce(function(s, l) { return s + (Number(l.askingPrice) || 0); }, 0);
      const soldProfit = listings.filter(function(l) { return l.status === "sold"; }).reduce(function(s, l) { return s + ((Number(l.askingPrice) || 0) - (Number(l.purchasePrice) || 0)); }, 0);

      const ADMIN_TABS = [
        { id: "listings", label: "LISTINGS", icon: "\u{1F3E0}" },
        { id: "analyzer", label: "DEAL ANALYZER", icon: "\u{1F9EE}" },
        { id: "ledger", label: "CAPITAL LEDGER", icon: "\u{1F4B0}" },
      ];

      return (
        <div style={{
          "--bg": "#0d0c08", "--card": "#141310", "--input-bg": "#1a1914",
          "--fg": "#e8e4d9", "--muted": "#7a7564", "--border": "#2a2720",
          "--gold": "#c9a227", "--gold-light": "#e8c84a", "--gold-dim": "#8b7a3a",
          "--display": "'Playfair Display', Georgia, serif",
          "--body": "'Cormorant Garamond', Georgia, serif",
          "--mono": "'JetBrains Mono', 'IBM Plex Mono', monospace",
          fontFamily: "var(--body)", background: "var(--bg)", color: "var(--fg)", minHeight: "100vh",
        }}>
          {showLogin && <AdminLogin onLogin={handleAdminLogin} />}
          {editing && isAdmin && (
            <ListingForm listing={editing === "new" ? null : editing}
              onSave={handleSave} onCancel={function() { setEditing(null); }} onDelete={handleDelete} />
          )}

          <nav style={{
            borderBottom: "1px solid var(--border)", padding: "0 32px",
            display: "flex", justifyContent: "space-between", alignItems: "center",
            height: 64, position: "sticky", top: 0, zIndex: 100,
            background: "rgba(13,12,8,0.9)", backdropFilter: "blur(20px)",
          }}>
            <div style={{ display: "flex", alignItems: "center", gap: 16 }}>
              <div style={{
                width: 36, height: 36, borderRadius: 2, border: "1px solid var(--gold-dim)",
                background: "rgba(201,162,39,0.06)",
                display: "flex", alignItems: "center", justifyContent: "center",
                fontFamily: "var(--display)", fontSize: 16, color: "var(--gold)", fontWeight: 600,
              }}>S</div>
              <div>
                <div style={{ fontSize: 14, fontWeight: 500, fontFamily: "var(--display)", color: "var(--fg)", letterSpacing: 1 }}>Sukup Capital Partners</div>
                <div style={{ fontSize: 9, fontFamily: "var(--mono)", letterSpacing: 3, color: "var(--gold-dim)" }}>PRIVATE LAND ACQUISITIONS</div>
              </div>
            </div>
            <div style={{ display: "flex", gap: 4, alignItems: "center" }}>
              {isAdmin ? (
                ["public", "manage"].map(function(v) { return (
                  <button key={v} onClick={function() { setView(v); }} style={{
                    padding: "7px 18px", borderRadius: 2,
                    border: "1px solid " + (view === v ? "var(--gold-dim)" : "transparent"),
                    background: view === v ? "rgba(201,162,39,0.06)" : "transparent",
                    color: view === v ? "var(--gold)" : "var(--muted)",
                    fontSize: 11, fontWeight: 500, cursor: "pointer",
                    fontFamily: "var(--mono)", letterSpacing: 2, textTransform: "uppercase",
                  }}>{v}</button>
                ); })
              ) : (
                <button onClick={function() { setShowLogin(true); }} style={{
                  padding: "7px 16px", borderRadius: 2, border: "1px solid var(--border)",
                  background: "transparent", color: "var(--muted)",
                  fontSize: 10, cursor: "pointer", fontFamily: "var(--mono)", letterSpacing: 2,
                }}>&#9672; ADMIN</button>
              )}
            </div>
          </nav>

          {view === "manage" && isAdmin ? (
            <div style={{ maxWidth: 1100, margin: "0 auto", padding: "32px 32px 60px" }}>

              <div style={{ display: "flex", gap: 4, marginBottom: 28, borderBottom: "1px solid var(--border)", paddingBottom: 0 }}>
                {ADMIN_TABS.map(function(t) {
                  return (
                    <button key={t.id} onClick={function() { setAdminTab(t.id); }} style={{
                      padding: "10px 20px", borderRadius: "2px 2px 0 0",
                      border: "1px solid " + (adminTab === t.id ? "var(--gold-dim)" : "transparent"),
                      borderBottom: adminTab === t.id ? "1px solid var(--bg)" : "1px solid transparent",
                      background: adminTab === t.id ? "rgba(201,162,39,0.06)" : "transparent",
                      color: adminTab === t.id ? "var(--gold)" : "var(--muted)",
                      fontSize: 11, fontWeight: 500, cursor: "pointer",
                      fontFamily: "var(--mono)", letterSpacing: 2, marginBottom: -1,
                    }}>{t.icon} {t.label}</button>
                  );
                })}
              </div>

              {adminTab === "listings" && (
                <div>
                  <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 14, marginBottom: 32 }}>
                    {[
                      { label: "Total Assets", value: listings.length, color: "var(--fg)" },
                      { label: "Capital Deployed", value: "$" + fmt(totalInvested), color: "var(--gold)" },
                      { label: "Portfolio Value", value: "$" + fmt(totalAsking), color: "var(--gold-light)" },
                      { label: "Realized P&L", value: (soldProfit >= 0 ? "+" : "") + "$" + fmt(soldProfit), color: soldProfit >= 0 ? "#4ade80" : "#ef4444" },
                    ].map(function(s) { return (
                      <div key={s.label} style={{ background: "var(--card)", borderRadius: 2, padding: "20px 22px", border: "1px solid var(--border)", position: "relative", overflow: "hidden" }}>
                        <div style={{ position: "absolute", top: 0, left: 0, right: 0, height: 1, background: "linear-gradient(90deg, transparent, rgba(201,162,39,0.2), transparent)" }} />
                        <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 2, textTransform: "uppercase", color: "var(--muted)", marginBottom: 8 }}>{s.label}</div>
                        <div style={{ fontSize: 24, fontWeight: 400, fontFamily: "var(--display)", color: s.color }}>{s.value}</div>
                      </div>
                    ); })}
                  </div>
                  <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 24, flexWrap: "wrap", gap: 10 }}>
                    <div style={{ display: "flex", gap: 4, flexWrap: "wrap" }}>
                      {[{ id: "all", label: "All" }].concat(Object.entries(STATUS_MAP).map(function([k, v]) { return { id: k, label: v.label }; })).map(function(f) { return (
                        <button key={f.id} onClick={function() { setFilter(f.id); }} style={{
                          padding: "6px 16px", borderRadius: 2,
                          border: "1px solid " + (filter === f.id ? "var(--gold-dim)" : "var(--border)"),
                          background: filter === f.id ? "rgba(201,162,39,0.08)" : "transparent",
                          color: filter === f.id ? "var(--gold)" : "var(--muted)",
                          fontSize: 11, cursor: "pointer", fontFamily: "var(--mono)", letterSpacing: 1,
                        }}>{f.label}</button>
                      ); })}
                    </div>
                    <button onClick={function() { setEditing("new"); }} style={{
                      padding: "10px 24px", borderRadius: 2, border: "none",
                      background: "linear-gradient(135deg, var(--gold), var(--gold-light))",
                      color: "#0d0c08", fontSize: 12, fontWeight: 600, cursor: "pointer",
                      fontFamily: "var(--mono)", letterSpacing: 2, display: "flex", alignItems: "center", gap: 8,
                    }}>
                      <span style={{ fontSize: 16, lineHeight: 1 }}>+</span> NEW LISTING
                    </button>
                  </div>
                  {filtered.length > 0 ? (
                    <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(330px, 1fr))", gap: 18 }}>
                      {filtered.map(function(l, i) { return (
                        <div key={l.id} style={{ animation: "fadeIn 0.4s ease " + (i * 0.05) + "s both" }}>
                          <ListingCard listing={l} onEdit={setEditing} />
                        </div>
                      ); })}
                    </div>
                  ) : (
                    <div style={{ padding: "80px 24px", borderRadius: 2, border: "1px solid var(--border)", textAlign: "center", background: "var(--card)" }}>
                      <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 4, color: "var(--gold-dim)", marginBottom: 16 }}>
                        {listings.length === 0 ? "EMPTY PORTFOLIO" : "NO MATCHING ASSETS"}
                      </div>
                      <div style={{ fontSize: 20, fontFamily: "var(--display)", fontWeight: 400, marginBottom: 8, color: "var(--fg)" }}>
                        {listings.length === 0 ? "No properties acquired yet" : "No listings match this filter"}
                      </div>
                      <div style={{ fontSize: 14, color: "var(--muted)", marginBottom: 24, fontFamily: "var(--body)" }}>
                        {listings.length === 0 ? "Add your first acquisition to begin building your portfolio." : "Try a different filter."}
                      </div>
                      {listings.length === 0 && (
                        <button onClick={function() { setEditing("new"); }} style={{
                          padding: "12px 32px", borderRadius: 2, border: "none",
                          background: "linear-gradient(135deg, var(--gold), var(--gold-light))",
                          color: "#0d0c08", fontSize: 12, fontWeight: 600, cursor: "pointer",
                          fontFamily: "var(--mono)", letterSpacing: 2,
                        }}>+ FIRST ACQUISITION</button>
                      )}
                    </div>
                  )}
                </div>
              )}

              {adminTab === "analyzer" && <DealAnalyzerTab />}
              {adminTab === "ledger" && <CapitalLedgerTab />}
            </div>
          ) : (
            <div>
              <div style={{ padding: "64px 32px 56px", textAlign: "center", position: "relative", overflow: "hidden" }}>
                <div style={{ position: "absolute", inset: 0, opacity: 0.03, backgroundImage: "linear-gradient(#c9a227 1px, transparent 1px), linear-gradient(90deg, #c9a227 1px, transparent 1px)", backgroundSize: "60px 60px" }} />
                <div style={{ position: "absolute", inset: 0, background: "radial-gradient(ellipse at 50% 80%, rgba(201,162,39,0.06) 0%, transparent 60%)" }} />
                <div style={{ position: "relative", zIndex: 1 }}>
                  <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 6, color: "var(--gold-dim)", marginBottom: 16 }}>SUKUP CAPITAL PARTNERS, LLC</div>
                  <h1 style={{ margin: "0 0 12px", fontSize: 42, fontWeight: 400, fontFamily: "var(--display)", color: "var(--fg)", letterSpacing: 1, lineHeight: 1.2 }}>Private Land Holdings</h1>
                  <GoldDivider style={{ maxWidth: 200, margin: "0 auto 16px" }} />
                  <p style={{ margin: "0 auto 20px", fontSize: 15, fontStyle: "italic", color: "var(--gold)", fontFamily: "var(--body)", maxWidth: 480, lineHeight: 1.7, letterSpacing: 0.3, opacity: 0.85 }}>
                    "The wise young man or wage earner of today invests his money in real estate."
                  </p>
                  <span style={{ fontSize: 11, fontFamily: "var(--mono)", letterSpacing: 3, color: "var(--gold-dim)", textTransform: "uppercase" }}>— Andrew Carnegie</span>
                </div>
              </div>

              <div style={{ maxWidth: 1100, margin: "0 auto", padding: "0 32px 60px" }}>
                {publicListings.length > 0 ? (
                  <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(330px, 1fr))", gap: 18 }}>
                    {publicListings.map(function(l, i) { return (
                      <div key={l.id} style={{ animation: "fadeIn 0.5s ease " + (i * 0.08) + "s both" }}>
                        <ListingCard listing={l} isPublic />
                      </div>
                    ); })}
                  </div>
                ) : (
                  <div style={{ padding: "80px 24px", borderRadius: 2, border: "1px solid var(--border)", textAlign: "center", background: "var(--card)" }}>
                    <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 4, color: "var(--gold-dim)", marginBottom: 12 }}>PORTFOLIO PENDING</div>
                    <div style={{ fontSize: 20, fontFamily: "var(--display)", color: "var(--fg)", marginBottom: 8 }}>No properties currently available</div>
                    <div style={{ fontSize: 14, color: "var(--muted)", fontFamily: "var(--body)" }}>New listings are released periodically. Check back soon.</div>
                  </div>
                )}

                <div style={{ marginTop: 56, padding: "40px 32px", borderRadius: 2, background: "var(--card)", border: "1px solid var(--border)", textAlign: "center", position: "relative", overflow: "hidden" }}>
                  <div style={{ position: "absolute", top: 0, left: 0, right: 0, height: 1, background: "linear-gradient(90deg, transparent, rgba(201,162,39,0.3), transparent)" }} />
                  <div style={{ fontSize: 10, fontFamily: "var(--mono)", letterSpacing: 4, color: "var(--gold-dim)", marginBottom: 12 }}>INQUIRIES</div>
                  <h3 style={{ margin: "0 0 12px", fontSize: 24, fontWeight: 400, fontFamily: "var(--display)", color: "var(--fg)" }}>Interested in a property?</h3>
                  <GoldDivider style={{ maxWidth: 120, margin: "0 auto 14px" }} />
                  <p style={{ margin: "0 0 4px", fontSize: 14, color: "var(--muted)", fontFamily: "var(--body)" }}>Sukup Capital Partners, LLC</p>
                  <p style={{ margin: "0 0 8px", fontSize: 13, color: "var(--gold)", fontFamily: "var(--mono)", letterSpacing: 1 }}>Contact us to discuss available parcels</p>
                  <p style={{ margin: 0, fontSize: 18, color: "#ef4444", fontFamily: "var(--mono)", fontWeight: 600, letterSpacing: 2 }}>
                    <a href="tel:5312139810" style={{ color: "#ef4444", textDecoration: "none" }}>531-213-9810</a>
                  </p>
                </div>
              </div>
            </div>
          )}

          <footer style={{ borderTop: "1px solid var(--border)", padding: "24px 32px", display: "flex", justifyContent: "space-between", alignItems: "center" }}>
            <div style={{ fontSize: 11, color: "var(--muted)", fontFamily: "var(--mono)", letterSpacing: 1 }}>© {new Date().getFullYear()} Sukup Capital Partners, LLC</div>
            <div style={{ fontSize: 10, color: "var(--gold-dim)", fontFamily: "var(--mono)", letterSpacing: 3 }}>SUKUPLAND.COM</div>
          </footer>
        </div>
      );
    }

    ReactDOM.createRoot(document.getElementById("root")).render(React.createElement(SukupListings));
  </script>
</body>
</html>
